{
  "family": "sales-intelligence-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "${{ vars.AWS_ECS_CPU || '256' }}",
  "memory": "${{ vars.AWS_ECS_MEMORY || '512' }}",
  "executionRoleArn": "arn:aws:iam::${{ env.ACCOUNT_ID }}:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::${{ env.ACCOUNT_ID }}:role/sales-intelligence-${ENVIRONMENT}",
  "containerDefinitions": [
    {
      "name": "${SERVICE}-container",
      "image": "${{ steps.login-ecr.outputs.registry }}/${{ env.ACCOUNT_ID }}/${{ env.REPOSITORY_NAME }}:${GITHUB_SHA}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${SERVICE}-${ENVIRONMENT}",
          "awslogs-region": "${{ env.REGION }}",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "SERVICE_NAME",
          "value": "${SERVICE}"
        }
      ],
      "secrets": [
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:${{ env.REGION }}:${{ env.ACCOUNT_ID }}:secret:sales-intelligence/${ENVIRONMENT}/GEMINI_API_KEY"
        },
        {
          "name": "FIREBASE_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:${{ env.REGION }}:${{ env.ACCOUNT_ID }}:secret:sales-intelligence/${ENVIRONMENT}/FIREBASE_PRIVATE_KEY"
        },
        {
          "name": "FIREBASE_CLIENT_EMAIL",
          "valueFrom": "arn:aws:secretsmanager:${{ env.REGION }}:${{ env.ACCOUNT_ID }}:secret:sales-intelligence/${ENVIRONMENT}/FIREBASE_CLIENT_EMAIL"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "placementConstraints": [
    {
      "type": "memberOf",
      "expression": "attribute:ecs.instance-type =~ t3.micro | t3.small | t3.medium"
    }
  ]
}