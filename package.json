{
  "name": "visualization",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "security:scan": "npm audit --audit-level=high",
    "smoke": "bash scripts/smoke-test.sh",
    "load:test": "node scripts/load-test.mjs",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run security:scan",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.0.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-joyride": "^3.1.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-joyride": "^2.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
