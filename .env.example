# Environment Variables Template
# Copy this file to .env.local and fill in your values

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# AWS S3 Configuration
S3_BUCKET_STATICS_PREFIX="sales-intelligence"
S3_BUCKET_STATS="sales-intelligence-stats"
S3_BUCKET_TRAINING="sales-intelligence-training"

# AWS ECR Configuration
ECR_REPOSITORY_NAME=sales-intelligence
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# AWS ECS Configuration
ECS_CLUSTER_PREFIX=sales-intelligence
ECS_CPU=var.512
ECS_MEMORY=var.1GB

# AWS Secrets Manager Configuration
AWS_SECRETS_PREFIX=sales-intelligence
GEMINI_API_KEY=your-gemini-api-key
FIREBASE_PRIVATE_KEY=your-firebase-private-key-here-with-
-for-newlines
-for-newlines
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Cloud Infrastructure
SERVICE_URL=https://your-service.amazonaws.com
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net
AWS_CLOUDFRONT_EDGE_COST=us-west-2
AWS_REQUEST_SCALABILITY=500
AWS_LAMBDA_LIMIT=50

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Production Configuration
CLOUD_RUN_MIN_INSTANCES=1
CLOUD_RUN_MAX_INSTANCES=20
PRODUCTION_DATABASE_HOST=your-rds-host.rds.amazonaws.com
PRODUCTION_DATABASE_PORT=5432
PRODUCTION_DATABASE_NAME=your-production-database
PRODUCTION_DATABASE_USER=your-database-user

# Development
SKIP_ENV_VALIDATION=true
NODE_ENV=development